# URL publica del sitio para metadata, Checkout y Open Graph.
NEXT_PUBLIC_SITE_URL=https://www.maquinariasmarmol.com.mx

# Servidor: llave secreta. Al configurarla, POST /api/stripe/create-checkout-session cambia de demo a produccion.
STRIPE_SECRET_KEY=

# Frontend: llave publicable de Stripe.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Servidor: secreto para validar eventos en POST /api/stripe/webhook.
STRIPE_WEBHOOK_SECRET=

# URL publica del sitio para metadata, checkout y Open Graph.
NEXT_PUBLIC_SITE_URL=https://www.maquinariasmarmol.com.mx

# Servidor: llave privada de Conekta. Al configurarla, POST /api/conekta/create-order cambia de demo a produccion.
CONEKTA_PRIVATE_KEY=

# Frontend: llave publica de Conekta.
NEXT_PUBLIC_CONEKTA_PUBLIC_KEY=

# Servidor: secreto para validar eventos en POST /api/conekta/webhook.
CONEKTA_WEBHOOK_SECRET=

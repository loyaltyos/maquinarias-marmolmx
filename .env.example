# URL pública del sitio para metadata Open Graph. Actualiza al conectar el dominio definitivo.
NEXT_PUBLIC_SITE_URL=https://maquinariasmarmol.com.mx

# Servidor: llave privada. Al configurarla, POST /api/conekta/create-order cambia de demo a producción.
CONEKTA_PRIVATE_KEY=

# Frontend: llave pública para tokenizar tarjetas con Conekta.js. Nunca coloques aquí la llave privada.
NEXT_PUBLIC_CONEKTA_PUBLIC_KEY=

# Servidor: secreto para validar eventos en POST /api/conekta/webhook.
CONEKTA_WEBHOOK_SECRET=
